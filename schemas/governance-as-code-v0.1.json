{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/hummbl-dev/governance-as-code/main/schemas/governance-as-code-v0.1.json",
  "title": "Governance-as-Code v0.1 Packet",
  "type": "object",
  "required": [
    "schemaVersion",
    "packetStatus",
    "governanceManifest",
    "authority",
    "gates",
    "receiptRequirements"
  ],
  "properties": {
    "schemaVersion": {
      "type": "string",
      "const": "v0.1"
    },
    "packetStatus": {
      "type": "string",
      "enum": ["seed", "v0.1-draft", "validated-example", "v0.1-packet"]
    },
    "governanceManifest": {
      "type": "object",
      "required": ["id", "title", "version", "scope"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9\\-]*/[a-z0-9][a-z0-9\\-]*$"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "scope": {
          "type": "string"
        },
        "description": {
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "authority": {
      "type": "object",
      "required": ["owner", "canActOnBehalfOf"],
      "properties": {
        "owner": {
          "type": "string"
        },
        "canActOnBehalfOf": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "requiresReceipt", "outcomes"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9\\-]+$"
          },
          "name": {
            "type": "string"
          },
          "requiresReceipt": {
            "type": "boolean"
          },
          "outcomes": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "enum": ["approve", "request_change", "escalate", "reject", "defer"]
            }
          },
          "escalationTriggers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reviewers": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": false
      }
    },
    "reviewPolicy": {
      "type": "object",
      "required": ["reviewRequired", "approverRole", "maxReviewDelayHours"],
      "properties": {
        "reviewRequired": {
          "type": "boolean"
        },
        "approverRole": {
          "type": "string"
        },
        "maxReviewDelayHours": {
          "type": "integer",
          "minimum": 1
        },
        "requiresProposalReceipt": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "exceptionPolicy": {
      "type": "object",
      "required": ["enabled", "requiresExceptionReceipt"],
      "properties": {
        "enabled": {
          "type": "boolean"
        },
        "requiresExceptionReceipt": {
          "type": "boolean"
        },
        "escalationTargets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      },
      "additionalProperties": false
    },
    "receiptRequirements": {
      "type": "object",
      "required": ["proposal", "review", "approval", "exception", "release"],
      "properties": {
        "proposal": {
          "type": "string",
          "minLength": 1
        },
        "review": {
          "type": "string",
          "minLength": 1
        },
        "approval": {
          "type": "string",
          "minLength": 1
        },
        "exception": {
          "type": "string",
          "minLength": 1
        },
        "release": {
          "type": "string",
          "minLength": 1
        }
      },
      "additionalProperties": false
    },
    "adjacentRepos": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": false
}
